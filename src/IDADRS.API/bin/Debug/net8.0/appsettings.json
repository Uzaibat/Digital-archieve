{
  "ConnectionStrings": {
    "Default": "Host=localhost;Port=5432;Database=idadrs;Username=idadrs_user;Password=CHANGE_ME"
  },
  "Jwt": {
    "Secret": "REPLACE_WITH_32_CHAR_MINIMUM_SECRET_KEY_HERE",
    "Issuer": "IDADRS",
    "Audience": "IDADRS-Client"
  },
  "Storage": {
    "RootPath": "/uploads",
    "HmacSecret": "REPLACE_WITH_STORAGE_HMAC_SECRET",
    "BaseUrl": "https://localhost:5001"
  },
  "Serilog": {
    "MinimumLevel": { "Default": "Information", "Override": { "Microsoft": "Warning" } },
    "WriteTo": [
      { "Name": "Console" },
      { "Name": "File", "Args": { "path": "logs/idadrs-.log", "rollingInterval": "Day" } }
    ]
  },
  "AllowedOrigins": [
    "http://localhost:3000",
    "http://localhost:5173",
    "https://your-replit-slug.replit.app"
  ],
  "AllowedHosts": "*"
}
